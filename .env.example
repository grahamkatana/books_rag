# Database -- SQLite by default for bare-host (`uv run python server.py`)
# use. The Dockerized path (`docker compose up`) overrides this to point
# at the postgres service instead -- see docker-compose.yml. Both work;
# this default only matters when running outside Docker.
DATABASE_URL=sqlite:///./book_rag.db

# Only used by the postgres service in docker-compose.yml (and only
# relevant when running via Docker) -- pick a real password before
# running this anywhere reachable by anyone but you.
POSTGRES_PASSWORD=book_rag_dev_password

# OpenAI
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072
DEFAULT_CHAT_MODEL=gpt-5.4-mini

# Brave Search -- optional. Powers automatic bibliography lookup
# (lookup-bibliography); without it that step is skipped and seed-books
# falls back to guessing from the filename instead. Costs real money
# (Brave Search has no free tier as of 2026; OpenAI calls for extraction
# are cheap but not free). Get a key at https://brave.com/search/api/
BRAVE_API_KEY=

# Qdrant -- defaults to the local instance from docker-compose.yml.
# Leave QDRANT_API_KEY blank unless you've uncommented the API key line
# in docker-compose.yml too.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=book_library

# Chunking
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=75

# Retrieval
DEFAULT_TOP_K=6

# Logging -- rotating JSON file (for Promtail/Loki/Grafana) + console.
# Defaults are fine for local dev; LOG_DIR matters mainly if you're
# running bare-host and want logs somewhere other than ./logs.
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Only used by the grafana service in docker-compose.yml -- change this
# before running anywhere reachable by anyone but you (default Grafana
# login is admin/admin otherwise, which is exactly as bad as it sounds).
GRAFANA_ADMIN_PASSWORD=admin

# Auth -- JWT secret for the API, session secret for the Flask-Admin
# panel. The defaults below are obviously-fake placeholders, fine for
# local dev only. Generate real values before deploying anywhere beyond
# your own machine: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev-only-insecure-jwt-secret-change-me
SECRET_KEY=dev-only-insecure-flask-secret-change-me
