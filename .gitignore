__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# OS noise
.DS_Store

# uv
.venv/

# frontend
frontend/node_modules/
frontend/dist/

# generated chunk manifest (regeneratable, tied to local pdfs/books/ content)
data/chunks/.manifest.json

# logs (rotating files, generated at runtime)
logs/
*.docx
backups/